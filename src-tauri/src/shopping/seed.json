  "spotlights": [
    {
      "id": "focus-sleep",
      "title": "睡眠系统仍然是当前最值得补齐的一组",
      "stage": "LongTermLiving",
      "summary": "床垫、遮光、除湿和睡前照明会一起决定第二天的恢复力。",
      "reason": "这不是买一件舒服单品,而是把每天都在用的系统先稳住。",
      "attention": [
        "把床垫、遮光帘、床边灯和除湿机放在同一张桌上看。",
        "优先补必要项,而不是先追求高折旧的幸福感大件。"
      ]
    },
    {
      "id": "focus-rhythm",
      "title": "补货节奏比一次性买满更重要",
      "stage": "本月补货",
      "summary": "洗衣液、常备药、垃圾袋这类消耗品如果没节奏,生活崩溃感会突然出现。",
      "reason": "lifecycle 决定动作,消耗品不是等想起来再补。",
      "attention": [
        "把消耗品单独看,避免和耐用品混在一个愿望清单里。",
        "消耗品不谈折旧率,重点是库存和补货窗口。"
      ]
    },
    {
      "id": "focus-tools",
      "title": "搬家最低配和应急工具还不够完整",
      "stage": "MovingMinimal",
      "summary": "卷尺、手电、插线板、常备药这些基础件很小,但缺一个就会卡住。",
      "reason": "工具类和最低配置更适合一次补齐,而不是临场救火。",
      "attention": [
        "把工具、应急和第一晚要用到的东西放进同一套最低配视角。",
        "工具和耐用品可以带折旧率,但别把它们丢进幸福感消费里看。"
      ]
    },
    {
      "id": "focus-fast-depreciation",
      "title": "高折旧幸福感物品要特别慢一点买",
      "stage": "购买判断",
      "summary": "投影仪、便携显示器这类东西往往不是最需要,却最容易被想象力放大。",
      "reason": "depreciation 是单件决策字段,不该主导整个分类,但该提醒你别在情绪最高点下单。",
      "attention": [
        "先确认使用频率和空间条件,再看品牌和新款。",
        "幸福感 + 极快折旧 的组合,需要比别的物品多一轮自查。"
      ]
    }
  ],
