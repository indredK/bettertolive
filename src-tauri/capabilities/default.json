{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "notification:default",
    {
      "identifier": "opener:allow-open-url",
      "allow": [{ "url": "https://github.com/**" }]
    },
    "dialog:default",
    {
      "identifier": "fs:scope",
      "allow": ["$APPDATA/**"]
    }
  ]
}
