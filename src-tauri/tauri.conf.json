{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "bettertolive",
  "version": "0.1.0",
  "identifier": "com.bettertolive.app",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:5001",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "bettertolive",
        "maximized": true,
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: https: data:; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
