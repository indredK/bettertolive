{
  "name": "bettertolive",
  "private": true,
  "version": "0.4.1",
  "type": "module",
  "scripts": {
    "start": "bun tauri dev",
    "dev": "vite",
    "build": "bun run lint && bun run typecheck && vite build",
    "build:bundle": "vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "fix:precommit": "bash ./scripts/pre-commit-auto-fix.sh",
    "check:precommit": "bash ./scripts/pre-commit-strict.sh",
    "test": "vitest",
    "analyze:bundle": "bun run lint && bun run typecheck && vite build --mode analyze",
    "db:reset": "rm -f ~/Library/Application\\ Support/com.bettertolive.app/bettertolive.db && echo 'DB reset. Run bun run start to rebuild.'",
    "db:reforge": "bun run db:reset && bun run start",
    "check:rust": "cargo fmt --manifest-path src-tauri/Cargo.toml --all --check && cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets --all-features -- -D warnings && cargo check --manifest-path src-tauri/Cargo.toml --all-targets --all-features",
    "generate:bindings": "cargo test --manifest-path src-tauri/Cargo.toml export_bindings -- --nocapture",
    "prepare": "husky",
    "commitlint": "commitlint --edit"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/geist": "^5.2.9",
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-slot": "^1.3.0",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-query-devtools": "^5.101.2",
    "@tanstack/react-router": "^1.170.17",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@tanstack/react-table": "^8.21.3",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-dialog": "~2.7.1",
    "@tauri-apps/plugin-fs": "~2.5.1",
    "@tauri-apps/plugin-notification": "~2.3.3",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-sql": "~2.4.0",
    "@tauri-apps/plugin-store": "~2.4.3",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cytoscape": "^3.34.0",
    "dayjs": "^1.11.21",
    "embla-carousel-autoplay": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "gsap": "^3.15.0",
    "i18next": "^26.3.4",
    "lucide-react": "^1.23.0",
    "motion": "^12.42.2",
    "nanoid": "^5.1.16",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-force-graph-3d": "^1.29.1",
    "react-hook-form": "^7.81.0",
    "react-i18next": "^17.0.8",
    "recharts": "^3.9.2",
    "shadcn": "^4.13.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/eslint-plugin-query": "^5.101.2",
    "@tanstack/eslint-plugin-router": "^1.162.0",
    "@tanstack/router-plugin": "^1.168.19",
    "@tauri-apps/cli": "^2.11.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/cytoscape": "^3.31.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "happy-dom": "^20.10.6",
    "husky": "^9.1.7",
    "prettier": "^3.9.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  }
}
